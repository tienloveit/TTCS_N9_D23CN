# MySQL
SPRING_DATASOURCE_PASSWORD=your_mysql_password

# Mail. For Gmail, use an app password instead of your account password.
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_mail_app_password

# JWT HS512 secret. Use a long random value.
JWT_SECRET_KEY=replace_with_a_long_random_jwt_secret_key

# VNPay sandbox
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_SECRET_KEY=your_vnpay_secret_key

# Gemini API key used by Spring AI through the OpenAI-compatible endpoint.
GEMINI_API_KEY=your_gemini_api_key

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
APP_OAUTH2_SUCCESS_URL=http://localhost:5173/oauth2/callback
APP_OAUTH2_FAILURE_URL=http://localhost:5173/login
